{
    "name": "vibeguard-monorepo",
    "version": "1.0.0",
    "private": true,
    "description": "VibeGuard - Cross-platform security scanning tool",
    "workspaces": [
        "core",
        "cli",
        "vscode-extension"
    ],
    "scripts": {
        "build": "npm run build --workspaces --if-present",
        "build:core": "npm run build --workspace=core",
        "build:cli": "npm run build --workspace=cli",
        "build:ext": "npm run compile --workspace=vscode-extension",
        "lint": "eslint . --ext .ts",
        "clean": "npm run clean --workspaces --if-present",
        "test": "npm run test --workspaces --if-present",
        "dev:cli": "npm run dev --workspace=cli"
    },
    "devDependencies": {
        "@typescript-eslint/eslint-plugin": "^6.21.0",
        "@typescript-eslint/parser": "^6.21.0",
        "eslint": "^8.57.0",
        "eslint-plugin-security": "^2.1.1",
        "prettier": "^3.2.5",
        "typescript": "^5.4.5"
    },
    "engines": {
        "node": ">=18.0.0",
        "npm": ">=9.0.0"
    },
    "keywords": [
        "security",
        "scanner",
        "static-analysis",
        "vulnerability",
        "linting"
    ],
    "license": "MIT",
    "author": "VibeGuard Contributors"
}