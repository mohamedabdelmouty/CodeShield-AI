{
    "name": "vibeguard-vscode",
    "displayName": "VibeGuard Security Scanner",
    "description": "Real-time security vulnerability detection for JS/TS — SQL Injection, XSS, Hardcoded Secrets, and more.",
    "version": "1.4.0",
    "publisher": "vibeguardapp",
    "galleryBanner": {
        "color": "#0f0f1a",
        "theme": "dark"
    },
    "engines": {
        "vscode": "^1.85.0"
    },
    "categories": [
        "Linters",
        "Other"
    ],
    "keywords": [
        "security",
        "vulnerability",
        "scanner",
        "linter",
        "static-analysis",
        "xss",
        "sql-injection"
    ],
    "activationEvents": [
        "onStartupFinished"
    ],
    "main": "./dist/extension.js",
    "contributes": {
        "viewsContainers": {
            "activitybar": [
                {
                    "id": "vibeguard-sidebar",
                    "title": "VibeGuard",
                    "icon": "$(shield)"
                }
            ]
        },
        "views": {
            "vibeguard-sidebar": [
                {
                    "type": "webview",
                    "id": "vibeguard.chatView",
                    "name": "VibeGuard AI Chat",
                    "icon": "$(comment-discussion)"
                }
            ]
        },
        "commands": [
            {
                "command": "vibeguard.scanWorkspace",
                "title": "VibeGuard: Scan Workspace",
                "icon": "$(shield)"
            },
            {
                "command": "vibeguard.scanFile",
                "title": "VibeGuard: Scan Current File",
                "icon": "$(search)"
            },
            {
                "command": "vibeguard.showReport",
                "title": "VibeGuard: Show Security Report",
                "icon": "$(graph)"
            },
            {
                "command": "vibeguard.clearDiagnostics",
                "title": "VibeGuard: Clear Diagnostics",
                "icon": "$(clear-all)"
            },
            {
                "command": "vibeguard.exportPdfReport",
                "title": "VibeGuard: Export Security Report to PDF",
                "icon": "$(export)"
            },
            {
                "command": "vibeguard.scanInSystemTerminal",
                "title": "VibeGuard: Scan in System Terminal",
                "icon": "$(terminal)"
            }
        ],
        "menus": {
            "editor/title": [
                {
                    "command": "vibeguard.scanFile",
                    "group": "navigation",
                    "when": "resourceExtname =~ /\\.(js|ts|jsx|tsx|mjs|cjs|py|java|dart|html|php|go|rb|c|cpp|cs|sh|yaml|yml|json)$/"
                },
                {
                    "command": "vibeguard.exportPdfReport",
                    "group": "navigation"
                }
            ],
            "editor/context": [
                {
                    "command": "vibeguard.scanFile",
                    "group": "security",
                    "when": "resourceExtname =~ /\\.(js|ts|jsx|tsx|mjs|cjs|py|java|dart|html|php|go|rb|c|cpp|cs|sh|yaml|yml|json)$/"
                }
            ],
            "commandPalette": [
                {
                    "command": "vibeguard.scanWorkspace"
                },
                {
                    "command": "vibeguard.scanFile"
                },
                {
                    "command": "vibeguard.showReport"
                },
                {
                    "command": "vibeguard.clearDiagnostics"
                },
                {
                    "command": "vibeguard.exportPdfReport"
                },
                {
                    "command": "vibeguard.scanInSystemTerminal"
                }
            ]
        },
        "configuration": {
            "title": "VibeGuard",
            "properties": {
                "vibeguard.enabled": {
                    "type": "boolean",
                    "default": true,
                    "description": "Enable or disable VibeGuard real-time scanning."
                },
                "vibeguard.scanOnSave": {
                    "type": "boolean",
                    "default": true,
                    "description": "Automatically scan files when they are saved."
                },
                "vibeguard.scanOnOpen": {
                    "type": "boolean",
                    "default": true,
                    "description": "Automatically scan files when they are opened."
                },
                "vibeguard.threshold": {
                    "type": "number",
                    "default": 70,
                    "minimum": 0,
                    "maximum": 100,
                    "description": "Minimum passing security score (0–100)."
                },
                "vibeguard.disabledRules": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    },
                    "default": [],
                    "description": "List of rule IDs to disable (e.g. [\"VG-RAND-001\"])."
                },
                "vibeguard.ignorePatterns": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    },
                    "default": [
                        "**/node_modules/**",
                        "**/dist/**",
                        "**/build/**"
                    ],
                    "description": "Glob patterns to exclude from scanning."
                },
                "vibeguard.showCodeLens": {
                    "type": "boolean",
                    "default": true,
                    "description": "Show inline CodeLens hints above vulnerable lines."
                },
                "vibeguard.enableAi": {
                    "type": "boolean",
                    "default": true,
                    "description": "Enable AI-powered vulnerability detection using Gemini (works automatically after install)."
                },
                "vibeguard.aiEndpoint": {
                    "type": "string",
                    "default": "https://generativelanguage.googleapis.com/v1beta/openai/chat/completions",
                    "description": "AI API endpoint. Defaults to Gemini — no change needed."
                },
                "vibeguard.aiApiKey": {
                    "type": "string",
                    "default": "",
                    "description": "Optional: Override the built-in Gemini API key. Leave empty to use the default."
                },
                "vibeguard.aiModel": {
                    "type": "string",
                    "default": "gemini-2.0-flash",
                    "description": "AI model name for vulnerability analysis."
                }
            }
        },
        "colors": [
            {
                "id": "vibeguard.criticalBackground",
                "description": "Background color for CRITICAL severity highlights",
                "defaults": {
                    "dark": "#ff000033",
                    "light": "#ff000022",
                    "highContrast": "#ff000055"
                }
            },
            {
                "id": "vibeguard.highBackground",
                "description": "Background color for HIGH severity highlights",
                "defaults": {
                    "dark": "#ff663333",
                    "light": "#ff663322",
                    "highContrast": "#ff663355"
                }
            }
        ]
    },
    "scripts": {
        "compile": "node build.js",
        "watch": "tsc -p tsconfig.json --watch",
        "package": "vsce package --no-dependencies",
        "publish": "vsce publish --no-dependencies",
        "vscode:prepublish": "npm run compile",
        "clean": "rimraf dist"
    },
    "devDependencies": {
        "@types/html2canvas": "^0.5.35",
        "@types/jspdf": "^1.3.3",
        "@types/node": "^20.12.7",
        "@types/vscode": "^1.85.0",
        "@vibeguard/core": "^1.4.0",
        "@vscode/vsce": "^2.24.0",
        "dotenv": "^17.4.1",
        "esbuild": "^0.28.0",
        "html2canvas": "^1.4.1",
        "jspdf": "^4.2.0",
        "rimraf": "^5.0.5",
        "typescript": "^5.4.5"
    },
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "https://github.com/vibeguard/vibeguard.git",
        "directory": "vscode-extension"
    },
    "bugs": {
        "url": "https://github.com/vibeguard/vibeguard/issues"
    },
    "homepage": "https://github.com/vibeguard/vibeguard#readme",
    "qna": "marketplace"
}
