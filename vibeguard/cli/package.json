{
    "name": "vibeguard",
    "version": "1.1.1",
    "description": "VibeGuard CLI — Cross-platform security scanner for JavaScript & TypeScript",
    "main": "dist/index.js",
    "bin": {
        "vibeguard": "dist/index.js"
    },
    "files": [
        "dist",
        "README.md",
        "LICENSE"
    ],
    "scripts": {
        "build": "tsc --project tsconfig.json",
        "dev": "tsc --project tsconfig.json --watch",
        "start": "node dist/index.js",
        "clean": "rimraf dist",
        "prepublishOnly": "npm run build"
    },
    "dependencies": {
        "@vibeguard/core": "^1.1.1",
        "chalk": "^5.3.0",
        "commander": "^12.0.0",
        "dotenv": "^17.4.1",
        "jspdf": "^4.2.0",
        "ora": "^8.0.1"
    },
    "devDependencies": {
        "@types/node": "^20.12.7",
        "rimraf": "^5.0.5",
        "typescript": "^5.4.5"
    },
    "engines": {
        "node": ">=18.0.0",
        "npm": ">=9.0.0"
    },
    "keywords": [
        "security",
        "scanner",
        "vulnerability",
        "static-analysis",
        "linting",
        "cli",
        "ast",
        "typescript",
        "javascript"
    ],
    "license": "MIT",
    "author": "VibeGuard Contributors",
    "repository": {
        "type": "git",
        "url": "https://github.com/vibeguard/vibeguard.git",
        "directory": "cli"
    },
    "bugs": {
        "url": "https://github.com/vibeguard/vibeguard/issues"
    },
    "homepage": "https://github.com/vibeguard/vibeguard#readme"
}
